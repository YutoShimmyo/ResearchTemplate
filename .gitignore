# Data not tracked by default
data/external_dataset/**
data/raw/**
data/interim/**
!data/external_dataset/.gitkeep
!data/raw/.gitkeep
!data/interim/.gitkeep

# Runs: keep metadata, ignore heavy artifacts and caches
runs/**/checkpoints/
runs/**/cache/
runs/**/tmp/
runs/**/*.ckpt
runs/**/*.pt
runs/**/*.pth
runs/**/*.bin
runs/**/*.onnx
runs/**/*.npy
runs/**/*.npz
runs/**/*.parquet
runs/**/*.pkl
runs/**/*.joblib
runs/**/*.h5
runs/**/*.feather

